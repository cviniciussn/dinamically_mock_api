<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= route && route.id ? 'Edit' : 'New' %> Route - Mock Server</title>
  <%- include('layout') %>
</head>
<body>
  <nav class="navbar">
    <h1>Mock Server</h1>
    <a href="/admin">Admin Panel</a>
  </nav>
  <div class="container">
    <div class="header-row">
      <h2><%= route && route.id ? 'Edit' : 'New' %> Route</h2>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form class="form-card"
          action="<%= route && route.id ? '/admin/routes/' + route.id : '/admin/routes' %>"
          method="POST">

      <div class="form-row">
        <div class="form-group">
          <label for="method">HTTP Method</label>
          <select name="method" id="method">
            <% ['GET','POST','PUT','PATCH','DELETE'].forEach(m => { %>
              <option value="<%= m %>" <%= (route && route.method === m) ? 'selected' : '' %>><%= m %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="path">Path</label>
          <input type="text" name="path" id="path" placeholder="/api/example" value="<%= route ? route.path || '' : '' %>" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="status_code">Status Code</label>
          <input type="number" name="status_code" id="status_code" value="<%= route ? route.status_code || 200 : 200 %>" min="100" max="599">
        </div>
        <div class="form-group">
          <label for="content_type">Content-Type</label>
          <select name="content_type" id="content_type">
            <% ['application/json','text/html','text/plain','application/xml'].forEach(ct => { %>
              <option value="<%= ct %>" <%= (route && route.content_type === ct) ? 'selected' : '' %>><%= ct %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="delay_ms">Delay (ms)</label>
          <input type="number" name="delay_ms" id="delay_ms" value="<%= route ? route.delay_ms || 0 : 0 %>" min="0">
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <input type="text" name="description" id="description" placeholder="Optional description" value="<%= route ? route.description || '' : '' %>">
        </div>
      </div>

      <div class="form-group">
        <label for="response_body">Response Body</label>
        <textarea name="response_body" id="response_body" placeholder='{"key": "value"}'><%= route ? route.response_body || '{}' : '{}' %></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><%= route && route.id ? 'Update Route' : 'Create Route' %></button>
        <a href="/admin" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    document.querySelector('form').addEventListener('submit', function(e) {
      const ct = document.getElementById('content_type').value;
      const body = document.getElementById('response_body').value;
      if (ct === 'application/json') {
        try {
          const parsed = JSON.parse(body);
          document.getElementById('response_body').value = JSON.stringify(parsed, null, 2);
        } catch (err) {
          e.preventDefault();
          alert('Invalid JSON: ' + err.message);
        }
      }
    });
  </script>
</body>
</html>
