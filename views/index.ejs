<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mock Server Admin</title>
  <%- include('layout') %>
</head>
<body>
  <nav class="navbar">
    <h1>Mock Server</h1>
    <a href="/admin">Admin Panel</a>
  </nav>
  <div class="container">
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="header-row">
      <h2>Mock Routes</h2>
      <a href="/admin/new" class="btn btn-primary">+ New Route</a>
    </div>

    <% if (routes.length === 0) { %>
      <div class="empty">
        <p>No mock routes configured yet.</p>
        <p style="margin-top:0.5rem"><a href="/admin/new" style="color:#38bdf8">Create your first route</a></p>
      </div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Status</th>
            <th>Delay</th>
            <th>Content-Type</th>
            <th>Description</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% routes.forEach(route => { %>
            <tr>
              <td><span class="method-badge method-<%= route.method %>"><%= route.method %></span></td>
              <td><code><%= route.path %></code></td>
              <td><%= route.status_code %></td>
              <td><%= route.delay_ms > 0 ? route.delay_ms + 'ms' : '-' %></td>
              <td><span style="font-size:0.75rem"><%= route.content_type %></span></td>
              <td class="description"><%= route.description || '-' %></td>
              <td>
                <div class="actions">
                  <a href="/admin/routes/<%= route.id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
                  <form action="/admin/routes/<%= route.id %>/delete" method="POST" onsubmit="return confirm('Delete this route?')">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
